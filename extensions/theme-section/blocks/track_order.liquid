<div class="container-parent" style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px; margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;">
  <div class="tracking-container">
    <div class="tracking-card">
      <div class="tracking-header">
        <div class="tracking-logo">
          <!-- SVG LOGO SAMA -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </div>
        <h1>Track Your Order</h1>
        <p class="subtitle">Enter your tracking number to check delivery status</p>
      </div>

      <!-- Search Form -->
      <div
        id="tracking-form"
        class="tracking-form {% if request.query_string contains 'tracking_number' %}hidden{% endif %}"
      >
        <!-- Courier Selection -->
        <div class="form-field">
          <label for="courier-select" class="form-label">Select Courier</label>
          <div class="select-wrapper">
            <select id="courier-select" class="form-select">
              <optgroup label="Direct Tracking (AWB Only)">
                <option value="tiki" selected>TIKI</option>
                <option value="jnt">J&amp;T Express</option>
                <option value="ninja">Ninja Xpress</option>
                <option value="ide">ID Express</option>
                <option value="lion">Lion Parcel</option>
                <option value="sap">SAP Express</option>
                <option value="anteraja">AnterAja</option>
                <option value="wahana">Wahana</option>
                <option value="pos">Pos Indonesia</option>
                <option value="sentral">Sentral Cargo</option>
                <option value="sicepat">SiCepat Express</option>
                {% comment %} <option value="spx">Shopee Express (SPX)</option> {% endcomment %}
              </optgroup>
              <optgroup label="Requires Phone Verification">
                <option value="jne">JNE (last 5 digits phone)</option>
              </optgroup>
            </select>
            <div class="select-arrow">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg>
            </div>
          </div>
        </div>

        <!-- AWB Input -->
        <div class="form-field">
          <label for="tracking-input" class="form-label">Tracking Number</label>
          <div class="input-group">
            <div class="input-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 12H4" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round" />
                <path d="M20 6H12" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round" />
                <path d="M20 18H8" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg>
            </div>
            <input type="text" id="tracking-input" placeholder="Enter tracking number (e.g. 123456789)" />
          </div>
        </div>

        <!-- Phone Number (conditional, shown for JNE/J&T/Sentral) -->
        <div id="phone-group" class="form-field phone-group" style="display:none;">
          <label class="form-label" id="phone-label">Last 5 digits of recipient's phone number</label>
          <div class="phone-notice">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M12 16V12" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round" />
              <path d="M12 8H12.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
            <span id="phone-notice-text">This courier requires phone verification for tracking.</span>
          </div>
          <div class="otp-container" id="otp-container">
            <!-- OTP digit boxes will be generated dynamically by JS -->
          </div>
        </div>

        <!-- Track Button -->
        <button onclick="updateTracking()" class="btn-track btn-track-full">
          <span>Track Order</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M12 5L19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </button>
      </div>

      <!-- Loading State -->
      <div
        id="tracking-loading"
        class="tracking-loading {% if request.query_string contains 'tracking_number' %}{% else %}hidden{% endif %}"
      >
        <div class="loading-spinner">
          <div class="spinner"></div>
        </div>
        <p>Loading shipment data...</p>
      </div>

      <!-- Error State -->
      <div id="tracking-error" class="tracking-error hidden">
        <div class="error-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M12 8V12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M12 16H12.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"
              stroke-linejoin="round" />
          </svg>
        </div>
        <p>Failed to retrieve data. Please try again.</p>
        <button onclick="updateTracking()" class="btn-retry">Try Again</button>
      </div>

      <!-- Results Container -->
      <div id="tracking-container" class="result-container hidden">
        <!-- Package info -->
        <div class="package-info">
          <div class="info-card">
            <div class="card-header">
              <h3>Shipment Details</h3>
              <span class="badge" id="status">-</span>
            </div>
            <div class="info-row">
              <div class="info-label">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path
                    d="M21 16V8.00002C20.9996 7.6493 20.9071 7.30483 20.7315 7.00119C20.556 6.69754 20.3037 6.44539 20 6.27002L13 2.27002C12.696 2.09449 12.3511 2.00208 12 2.00208C11.6489 2.00208 11.304 2.09449 11 2.27002L4 6.27002C3.69626 6.44539 3.44398 6.69754 3.26846 7.00119C3.09294 7.30483 3.00036 7.6493 3 8.00002V16C3.00036 16.3508 3.09294 16.6952 3.26846 16.9989C3.44398 17.3025 3.69626 17.5547 4 17.73L11 21.73C11.304 21.9056 11.6489 21.998 12 21.998C12.3511 21.998 12.696 21.9056 13 21.73L20 17.73C20.3037 17.5547 20.556 17.3025 20.7315 16.9989C20.9071 16.6952 20.9996 16.3508 21 16Z"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M3.27002 6.96002L12 12.01L20.73 6.96002" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M12 22.08V12" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round" />
                </svg>
                <span>Tracking Number</span>
              </div>
              <div class="info-value" id="resi">-</div>
            </div>
            <div class="info-row">
              <div class="info-label">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M16 3H1V16H16V3Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path d="M16 8H20L23 11V16H16V8Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round" />
                  <path
                    d="M5.5 21C6.88071 21 8 19.8807 8 18.5C8 17.1193 6.88071 16 5.5 16C4.11929 16 3 17.1193 3 18.5C3 19.8807 4.11929 21 5.5 21Z"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  <path
                    d="M18.5 21C19.8807 21 21 19.8807 21 18.5C21 17.1193 19.8807 16 18.5 16C17.1193 16 16 17.1193 16 18.5C16 19.8807 17.1193 21 18.5 21Z"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>Courier</span>
              </div>
              <div class="info-value" id="kurir">-</div>
            </div>
            {% comment %}
              <div class="info-row">
                <div class="info-label">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
                      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                      stroke-linejoin="round" />
                  </svg>
                  <span>Estimated Arrival</span>
                </div>
                <div class="info-value highlight" id="estimasi">-</div>
              </div>
            {% endcomment %}
          </div>
        </div>
        <!-- Timeline -->
        <div class="timeline-section">
          <h3>Shipment History</h3>
          <div class="timeline" id="tracking-timeline"></div>
        </div>

        <!-- Reset Button -->
        <div class="reset-section">
          <button onclick="resetTracking()" class="btn-reset">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 4V10H7" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round" />
              <path
                d="M3.51 15C4.15839 16.8404 5.38734 18.4202 7.01166 19.5014C8.63598 20.5826 10.5677 21.1066 12.5157 20.9945C14.4637 20.8824 16.3226 20.1402 17.8121 18.8798C19.3017 17.6193 20.3413 15.9090 20.7742 14.0064C21.2072 12.1037 21.0101 10.1119 20.2126 8.33109C19.4152 6.55025 18.0605 5.07674 16.3528 4.13272C14.6451 3.18871 12.6769 2.82521 10.7447 3.09711C8.81245 3.36901 7.02091 4.26142 5.64 5.64L1 10"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Track Another Order</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  window.addEventListener('load', function () {
    const formEl = document.getElementById('tracking-form');
    const loadingEl = document.getElementById('tracking-loading');
    const errorEl = document.getElementById('tracking-error');
    const containerEl = document.getElementById('tracking-container');
    const resiEl = document.getElementById('resi');
    const kurirEl = document.getElementById('kurir');
    const statusEl = document.getElementById('status');
    const timelineEl = document.getElementById('tracking-timeline');
    const trackingInput = document.getElementById('tracking-input');
    const courierSelect = document.getElementById('courier-select');
    const phoneGroup = document.getElementById('phone-group');
    const otpContainer = document.getElementById('otp-container');
    const phoneLabel = document.getElementById('phone-label');
    const phoneNoticeText = document.getElementById('phone-notice-text');
    let currentOtpDigits = 0;

    // Couriers that require last digits of recipient's phone number
    const COURIER_PHONE_DIGITS = {
      jne: 5,
    };

    const COURIER_NAMES = {
      jne: 'JNE',
    };

    // Build OTP digit boxes
    function buildOtpBoxes(count) {
      otpContainer.innerHTML = '';
      for (let i = 0; i < count; i++) {
        const input = document.createElement('input');
        input.type = 'text';
        input.inputMode = 'numeric';
        input.pattern = '[0-9]';
        input.maxLength = 1;
        input.className = 'otp-box';
        input.dataset.index = i;
        input.setAttribute('aria-label', `Digit ${i + 1} of ${count}`);

        // Auto-advance on input
        input.addEventListener('input', function (e) {
          const val = this.value.replace(/[^0-9]/g, '');
          this.value = val;
          if (val && i < count - 1) {
            otpContainer.children[i + 1].focus();
          }
          // If all filled, auto-submit-ready visual
          updateOtpFilledState(count);
        });

        // Handle backspace to go to previous box
        input.addEventListener('keydown', function (e) {
          if (e.key === 'Backspace' && !this.value && i > 0) {
            otpContainer.children[i - 1].focus();
            otpContainer.children[i - 1].value = '';
            e.preventDefault();
          }
          if (e.key === 'Enter') {
            updateTracking();
          }
          // Arrow keys navigation
          if (e.key === 'ArrowLeft' && i > 0) {
            otpContainer.children[i - 1].focus();
            e.preventDefault();
          }
          if (e.key === 'ArrowRight' && i < count - 1) {
            otpContainer.children[i + 1].focus();
            e.preventDefault();
          }
        });

        // Handle paste across all boxes
        input.addEventListener('paste', function (e) {
          e.preventDefault();
          const pasteData = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '');
          for (let j = 0; j < count && j < pasteData.length; j++) {
            otpContainer.children[j].value = pasteData[j];
          }
          const focusIdx = Math.min(pasteData.length, count) - 1;
          if (focusIdx >= 0) otpContainer.children[focusIdx].focus();
          updateOtpFilledState(count);
        });

        // Focus highlight
        input.addEventListener('focus', function () {
          this.select();
        });

        otpContainer.appendChild(input);
      }
      currentOtpDigits = count;
    }

    // Visual feedback when all OTP boxes are filled
    function updateOtpFilledState(count) {
      const allFilled = getOtpValue().length === count;
      otpContainer.classList.toggle('otp-filled', allFilled);
    }

    // Get combined value from all OTP boxes
    function getOtpValue() {
      let val = '';
      const boxes = otpContainer.querySelectorAll('.otp-box');
      boxes.forEach((b) => {
        val += b.value;
      });
      return val;
    }

    // Set OTP value (for URL params restore)
    function setOtpValue(value) {
      const boxes = otpContainer.querySelectorAll('.otp-box');
      for (let i = 0; i < boxes.length && i < value.length; i++) {
        boxes[i].value = value[i];
      }
    }

    // Clear OTP boxes
    function clearOtpBoxes() {
      const boxes = otpContainer.querySelectorAll('.otp-box');
      boxes.forEach((b) => {
        b.value = '';
      });
      otpContainer.classList.remove('otp-filled');
    }

    // Show/hide phone input based on selected courier
    function updatePhoneFieldVisibility() {
      const courier = courierSelect.value;
      const requiredDigits = COURIER_PHONE_DIGITS[courier];
      if (requiredDigits) {
        const courierName = COURIER_NAMES[courier] || courier.toUpperCase();
        phoneLabel.textContent = `Last ${requiredDigits} digits of recipient's phone number`;
        phoneNoticeText.textContent = `${courierName} requires the last ${requiredDigits} digits of the recipient's phone number for tracking.`;
        // Rebuild OTP boxes if digit count changed
        if (currentOtpDigits !== requiredDigits) {
          buildOtpBoxes(requiredDigits);
        }
        phoneGroup.style.display = 'block';
        requestAnimationFrame(() => {
          phoneGroup.style.opacity = '1';
          phoneGroup.style.transform = 'translateY(0)';
        });
      } else {
        phoneGroup.style.opacity = '0';
        phoneGroup.style.transform = 'translateY(-10px)';
        setTimeout(() => {
          phoneGroup.style.display = 'none';
        }, 250);
        clearOtpBoxes();
      }
    }

    courierSelect.addEventListener('change', updatePhoneFieldVisibility);
    // Initialize on load
    updatePhoneFieldVisibility();

    function mapStatusClass(statusRaw) {
      const status = (statusRaw || '').toLowerCase();
      if (status.includes('deliver')) return 'success';
      if (status.includes('transit') || status.includes('on process') || status.includes('process')) return 'progress';
      if (status.includes('hold') || status.includes('problem')) return 'error';
      if (status.includes('cancel') || status.includes('reject')) return 'error';
      return 'info';
    }

    function formatStatusLabel(statusRaw) {
      if (!statusRaw) return 'Unknown';
      if (statusRaw.toUpperCase() === 'DELIVERED') return 'Delivered';
      if (statusRaw.toUpperCase() === 'ON PROCESS') return 'In Process';
      if (statusRaw.toUpperCase() === 'ON TRANSIT') return 'In Transit';
      return statusRaw.replace(/_/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase());
    }

    // Main function to fetch tracking data from RajaOngkir Proxy
    async function fetchTrackingInfo(trackingNumber, courier, lastPhoneNumber) {
      if (!trackingNumber) {
        loadingEl.textContent = 'Please enter a tracking number first.';
        loadingEl.classList.remove('hidden');
        errorEl.classList.add('hidden');
        containerEl.classList.add('hidden');
        formEl.classList.remove('hidden');
        return;
      }
      try {
        loadingEl.classList.remove('hidden');
        errorEl.classList.add('hidden');
        containerEl.classList.add('hidden');
        formEl.classList.add('hidden');

        const requestBody = {
          awb: trackingNumber,
          courier: courier,
        };
        // Only include last_phone_number if the courier requires it
        if (lastPhoneNumber) {
          requestBody.last_phone_number = lastPhoneNumber;
        }

        const res = await fetch('https://jubelio-proxy-6m9y.vercel.app/api/tracking', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(requestBody),
        });
        const data = await res.json();

        if (!data || !data.data || !data.meta || data.meta.code !== 200)
          throw new Error(data?.meta?.message || 'Unknown API error');

        loadingEl.classList.add('hidden');
        containerEl.classList.remove('hidden');

        const summary = data.data.summary;

        resiEl.textContent = summary.waybill_number || '-';
        kurirEl.textContent = summary.courier_name || '-';
        statusEl.textContent = formatStatusLabel(summary.status) || '-';
        statusEl.className = `badge ${mapStatusClass(summary.status)}`;

        timelineEl.innerHTML = '';
        if (data.data.manifest && Array.isArray(data.data.manifest)) {
          const sortedHistory = [...data.data.manifest].sort((a, b) => {
            const dateA = new Date(`${a.manifest_date}T${a.manifest_time}`);
            const dateB = new Date(`${b.manifest_date}T${b.manifest_time}`);
            return dateB - dateA;
          });
          sortedHistory.forEach((item, index) => {
            const date = new Date(`${item.manifest_date}T${item.manifest_time}`);
            const time = date.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
            const day = date.toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' });

            let desc = item.manifest_description && item.manifest_description.trim();
            let city = item.city_name && item.city_name.trim();
            let note = '';
            if (desc && city) {
              note = `${desc} - ${city}`;
            } else if (desc) {
              note = desc;
            } else if (city) {
              note = city;
            } else {
              note = '-';
            }

            const timelineItem = document.createElement('div');
            timelineItem.className = `timeline-item ${index === 0 ? 'active' : ''}`;
            timelineItem.innerHTML = `
            <div class="timeline-point"></div>
            <div class="timeline-content">
              <div class="timeline-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M12 6V12L16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                ${day} - ${time}
              </div>
              <p class="timeline-note">${note}</p>
            </div>
          `;
            timelineEl.appendChild(timelineItem);
          });
        } else {
          timelineEl.innerHTML = `<div class="timeline-item">
          <div class="timeline-point"></div>
          <div class="timeline-content"><p class="timeline-note">Tracking history not available.</p></div>
        </div>`;
        }
        setTimeout(() => {
          const items = document.querySelectorAll('.timeline-item');
          items.forEach((item, i) => {
            setTimeout(() => {
              item.style.opacity = '1';
            }, i * 150);
          });
        }, 300);
      } catch (err) {
        loadingEl.classList.add('hidden');
        errorEl.classList.remove('hidden');
        errorEl.querySelector('p').textContent = 'Failed to retrieve data: ' + err.message;
        containerEl.classList.add('hidden');
        formEl.classList.remove('hidden');
      }
    }

    // Manual submit with validation
    window.updateTracking = function () {
      const trackingNumber = trackingInput.value.trim();
      const courier = courierSelect.value;
      const requiredDigits = COURIER_PHONE_DIGITS[courier];
      let lastPhoneNumber = null;

      if (!trackingNumber) {
        errorEl.classList.remove('hidden');
        errorEl.querySelector('p').textContent = 'Tracking number cannot be empty';
        loadingEl.classList.add('hidden');
        containerEl.classList.add('hidden');
        return;
      }

      // Validate phone number if courier requires it
      if (requiredDigits) {
        const phoneVal = getOtpValue();
        if (!phoneVal || phoneVal.length !== requiredDigits) {
          errorEl.classList.remove('hidden');
          const courierName = COURIER_NAMES[courier] || courier.toUpperCase();
          const missing = requiredDigits - phoneVal.length;
          errorEl.querySelector('p').textContent =
            phoneVal.length === 0
              ? `${courierName} requires the last ${requiredDigits} digits of the recipient's phone number.`
              : `Please enter all ${requiredDigits} digits (${missing} remaining).`;
          loadingEl.classList.add('hidden');
          containerEl.classList.add('hidden');
          // Focus first empty box
          const boxes = otpContainer.querySelectorAll('.otp-box');
          for (let i = 0; i < boxes.length; i++) {
            if (!boxes[i].value) {
              boxes[i].focus();
              break;
            }
          }
          otpContainer.classList.add('otp-error');
          setTimeout(() => otpContainer.classList.remove('otp-error'), 2000);
          return;
        }
        lastPhoneNumber = phoneVal;
      }

      // Build URL with params
      let newUrl = `${window.location.pathname}?tracking_number=${encodeURIComponent(
        trackingNumber
      )}&courier=${encodeURIComponent(courier)}`;
      if (lastPhoneNumber) {
        newUrl += `&phone=${encodeURIComponent(lastPhoneNumber)}`;
      }
      window.history.pushState({}, '', newUrl);
      fetchTrackingInfo(trackingNumber, courier, lastPhoneNumber);
    };

    // Press Enter on tracking input
    trackingInput.addEventListener('keyup', function (event) {
      if (event.key === 'Enter') updateTracking();
    });

    // Auto-run if tracking_number in URL
    const params = new URLSearchParams(window.location.search);
    const trackingNumber = params.get('tracking_number');
    const courierParam = params.get('courier');
    const phoneParam = params.get('phone');
    if (trackingNumber) {
      trackingInput.value = trackingNumber;
      if (courierParam) courierSelect.value = courierParam;
      updatePhoneFieldVisibility();
      if (phoneParam) setOtpValue(phoneParam);
      fetchTrackingInfo(trackingNumber, courierParam || courierSelect.value, phoneParam || null);
    } else {
      formEl.classList.remove('hidden');
      loadingEl.classList.add('hidden');
    }

    // Reset tracking to start fresh
    window.resetTracking = function () {
      containerEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      loadingEl.classList.add('hidden');
      formEl.classList.remove('hidden');
      trackingInput.value = '';
      clearOtpBoxes();
      courierSelect.selectedIndex = 0;
      updatePhoneFieldVisibility();
      window.history.pushState({}, '', window.location.pathname);
      trackingInput.focus();
      // Scroll back to top of form
      document.querySelector('.tracking-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    // Fade in anim
    document.querySelector('.tracking-card').style.opacity = 0;
    setTimeout(() => {
      document.querySelector('.tracking-card').style.opacity = 1;
      document.querySelector('.tracking-card').style.transform = 'translateY(0)';
    }, 100);
  });
</script>

